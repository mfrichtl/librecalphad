
$ ----------------------------------------------------------------------------
$ ELEMENT /-   ELECTRON_GAS              0.0000E+00  0.0000E+00  0.0000E+00 !

ELEMENT FE BCC_A2 55.847 3718.0079910811764 13.780316762269202 !
ELEMENT VA VACUUM 0.0 0.0 0.0 !


FUNCTION GBCCFE 1E-05 GHSERFE; 10000.0 N !

FUNCTION GHSERFE 1E-05 -0.00485009915606545*T**(2); 1708.80064303379 Y 
  -358851.525365491-1*(630.00595211924*T*LOG(T)+0.000107877744914721*T**(3)
  -3744.47000249661*T-0.727666041205115*T**(2))+7.19184966098143E-05*T**(3)
  +630.00595211924*T-0.363833020602558*T**(2); 1804.13794113749 Y
   63476.4202677775-1*(-72.2595498750166*T*LOG(T)+467.60482504121*T
  +0.0508392892148903*T**(2))-72.2595498750166*T+0.0254196446074451*T**(2);
   10000.0 N !

FUNCTION GFCCFE 1E-05 -0.00310761074266988*T**(2); 1984.07193146371 Y 
  -218197.501564197-1*(329.923776609087*T*LOG(T)+4.19052844407993E-05*T**(3)
  -2010.19473718145*T-0.32635717307063*T**(2))+2.79368562938662E-05*T**(3)
  +329.923776609087*T-0.163178586535315*T**(2); 2178.37093114661 Y
   70586.4354304537-1*(-67.7825086689391*T*LOG(T)+450.148619521559*T
  +0.0387838408784391*T**(2))-67.7825086689391*T+0.0193919204392195*T**(2);
   10000.0 N !

FUNCTION GHSERVA 1E-5 0; 10000 N !

TYPE_DEFINITION % SEQ * !

$ BCC MAGNETIC MODEL
TYPE_DEFINITION A GES AMEND_PHASE_DESCRIPTION @ MAGNETIC 0 0.37 !

$ N0N-BCC MAGNETIC MODEL
TYPE_DEFINITION B GES AMENED_PHASE_DESCRIPTION @ MAGNETIC 0 0.28 !

$ ---------------------- INTERACTIONS ----------------------------

$ -- BCC_A2 --
PHASE BCC_A2 %A 2 1 3 !
CONSTITUENT BCC_A2 : FE : VA : !

$ PARAMETER BMAGN(BCC_A2,FE:C;0) 298.15 +2.22; 6000 N 85GUS!
$ PARAMETER TC(BCC_A2,FE:C;0) 298.15 +1043; 6000 N 85GUS!
PARAMETER BMAGN(BCC_A2,FE:VA;0) 1E-5 +2.22; 10000 N 91DIN!
PARAMETER TC(BCC_A2,FE:VA;0) 1E-5 +1043; 10000 N 91DIN!
PARAMETER THETA(BCC_A2,FE:VA;0) 1E-5 5.77543366; 10000 N !

$ -- CEMENTITE_D011 --
$ PHASE CEMENTITE_D011 %B 2 3 1 !
$ CONSTITUENT CEMENTITE_D011 : FE : C : !
$ 
$ PARAMETER BMAGN(CEMENTITE_D011,FE:C;0) 298.15 1.008;  6000 N !
$ PARAMETER TC(CEMENTITE_D011,FE:C;0) 298.15  +485; 6000 N !

$ -- FCC_A1 --
PHASE FCC_A1 %B 2 1 1 !
CONSTITUENT FCC_A1 : FE : VA : !

$ PARAMETER BMAGN(FCC_A1,FE:C;0) 298.15 -2.1;  6000 N 85GUS!
$ PARAMETER TC(FCC_A1,FE:C;0) 298.15 -201;  6000 N 85GUS!
PARAMETER BMAGN(FCC_A1,FE:VA;0) 1E-5 0.7;  10000 N 91DIN!
PARAMETER NT(FCC_A1,FE:VA;0) 1E-5 +67;  10000 N 03WIT!
